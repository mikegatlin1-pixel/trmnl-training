# Copy this file to .env on the NAS and fill in the secret values there.
# Do not commit .env.

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

WEATHER_LAT=34.85
WEATHER_LON=-82.39
WEEKLY_GOAL_MI=20

# Optional: Google Sheets fallback if you decide to store training plan rows there.
GOOGLE_SHEET_ID=
GOOGLE_CREDS_JSON=

# NAS host paths mounted into the dashboard container.
# Update these to the real UGREEN NAS paths.
RUNNING_COACH_HOST_DIR=/volume1/docker/trmnl-strava/running-coach
STRAVA_WORKOUTS_HOST_DIR=/volume1/docker/trmnl-strava/workouts

# Bind only locally by default. Cloudflare Tunnel reaches the app over Docker networking.
STRAVA_DASHBOARD_BIND=127.0.0.1:8080

# Paste the token from Cloudflare Zero Trust > Networks > Tunnels.
CLOUDFLARE_TUNNEL_TOKEN=
